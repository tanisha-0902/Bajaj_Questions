class Solution {
    public List<String> generateParenthesis(int n) {
        List<String> list=new ArrayList<>();
        backtrack(n,"",0,0,list);
        return list;
    }
    public void backtrack(int n,String current,int open,int close,List<String> list){
        if(current.length()==2*n){
            list.add(current);
            return;
        }
        if(open<n){
            backtrack(n,current+"(",open+1,close,list);
        }
        if(close<open){
            backtrack(n,current+")",open,close+1,list);
        }
    }
}
