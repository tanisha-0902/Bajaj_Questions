class Solution {
    public static int findEquilibrium(int arr[]) {
        // code here
        int leftSum = 0;
        int totalSum = 0;

        for (int i : arr) {
            totalSum += i;
        }

        for (int i = 0; i < arr.length; i++) {
            totalSum -= arr[i];
            if (leftSum == totalSum) {
                return i;
            }
            leftSum += arr[i];
        }
        return -1;
    }
}
